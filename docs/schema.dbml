// Shyraq — Database Schema
// dbdiagram.io

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

Enum staff_role {
  admin
  mentor
  specialist
  reception
}

Enum child_status {
  card_created
  active
  archived
}

Enum guardian_role {
  primary
  secondary
  nanny
}

Enum guardian_status {
  pending_approval
  approved
  rejected
  revoked
}

Enum enrollment_status {
  new
  in_processing
  waitlist
  card_created
  cancelled
  archive
}

Enum attendance_event_type {
  check_in
  check_out
}

Enum attendance_method {
  face_id
  manual
  otp_pickup
}

Enum child_intraday_status {
  present
  absent
  sick
  late
  early_pickup
  on_vacation
}

Enum timeline_entry_type {
  check_in
  check_out
  activity
  meal
  nap
  note
  photo
  mood
  medication
}

Enum payment_status {
  pending
  partial
  paid
  overdue
  refunded
  cancelled
}

Enum payment_type {
  monthly
  prepayment_3m
  prepayment_6m
  prepayment_12m
  prepayment_24m
  additional_service
  late_pickup_fee
  other
}

Enum parent_request_type {
  trusted_person
  day_off
  late_pickup
  vacation
  open_request
}

Enum parent_request_status {
  pending
  accepted
  rejected
  cancelled
}

Enum content_type {
  news
  menu
  schedule_pub
  qundylyq
  birthday
}

Enum content_target_type {
  all
  group
  child
}

Enum content_status {
  draft
  scheduled
  published
}

Enum tariff_type {
  monthly_base
  additional_service
  late_pickup
  meal_upgrade
}

Enum fiscal_receipt_status {
  pending
  issued
  failed
  cancelled
}

Enum refund_status {
  pending
  approved
  processed
  rejected
}

// B13: payment_status_v2 — used by payments table (separate from payment_status used by invoices)
Enum payment_status_v2 {
  initiated
  processing
  completed
  failed
  refunded
}

Enum face_subject_type {
  child
  guardian
  staff
}

Enum face_event_type {
  child_checkin
  child_checkout
  guardian_pickup
  unknown
}

Enum face_event_status {
  matched
  unmatched
  manual_override
  rejected_low_confidence
  rejected_spoof
}

Enum liveness_method {
  none
  passive
  active_blink
}

Enum custom_discount_status {
  draft
  active
  paused
  expired
  cancelled
}

Enum custom_discount_type {
  percentage
  fixed_amount
}

Enum qr_purpose {
  identity
}

Enum meal_type {
  breakfast
  snack_am
  lunch
  snack_pm
  dinner
}

Enum activity_event_status {
  scheduled
  in_progress
  completed
  cancelled
}

Enum saas_user_role {
  super_admin
  support
}

Enum subscription_status {
  active
  trial
  suspended
  cancelled
}

// ─────────────────────────────────────────
// CORE / TENANCY
// ─────────────────────────────────────────

Table kindergartens {
  id              uuid      [pk, default: `gen_random_uuid()`]
  name            varchar   [not null]
  slug            varchar   [unique, not null]
  address         text
  phone           varchar
  settings        jsonb     [not null, default: `{}`]
  // timezone, currency, late_pickup_fee_amount,
  // otp_expiry_seconds, prepay_3m/6m/12m_discount, payment_grace_days
  plan            varchar   [not null, default: 'standard']
  is_active       boolean   [not null, default: true]
  created_at      timestamptz [not null, default: `now()`]
  updated_at      timestamptz [not null, default: `now()`]
}

Table users {
  id            uuid        [pk, default: `gen_random_uuid()`]
  phone         varchar(20) [unique, not null]
  full_name     varchar     [not null]
  avatar_url    text
  iin           char(12)    [unique]
  date_of_birth date
  locale        varchar(5)  [not null, default: 'ru'] // 'ru' | 'kk'
  is_active     boolean     [not null, default: true]
  last_login_at timestamptz
  created_at    timestamptz [not null, default: `now()`]
  updated_at    timestamptz [not null, default: `now()`]

  indexes {
    phone
    iin
  }
}

Table refresh_tokens {
  id              uuid        [pk, default: `gen_random_uuid()`]
  user_id         uuid        [not null, ref: > users.id]
  kindergarten_id uuid        [ref: > kindergartens.id]
  token_hash      varchar     [unique, not null]
  device_id       varchar
  ip_address      varchar
  audience        varchar(16) // 'parent'|'staff'|'admin'; NULL for legacy rows (no audience filter on refresh)
  expires_at      timestamptz [not null]
  revoked_at      timestamptz
  created_at      timestamptz [not null, default: `now()`]
}

// ─────────────────────────────────────────
// STAFF
// ─────────────────────────────────────────

Table staff_members {
  id              uuid       [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid       [not null, ref: > kindergartens.id]
  user_id         uuid       [not null, ref: > users.id]
  role            staff_role [not null]
  specialist_type varchar    // 'psychologist', 'speech_therapist', etc.
  is_active       boolean    [not null, default: true]
  hired_at        date
  fired_at        date
  created_at      timestamptz [not null, default: `now()`]
  updated_at      timestamptz [not null, default: `now()`]

  indexes {
    (kindergarten_id, user_id) [unique, name: 'idx_staff_members_kg_user_active'] // PARTIAL: WHERE is_active = true — deactivate→reactivate cycles must not collide (see migration 1777593602000-StaffAndKindergartenSettings.ts)
    (kindergarten_id, role)
  }
}

// ─────────────────────────────────────────
// GROUPS & LOCATIONS
// ─────────────────────────────────────────

Table locations {
  id              uuid [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid [not null, ref: > kindergartens.id]
  name            varchar [not null]
  description     text
  created_at      timestamptz [not null, default: `now()`]
}

Table groups {
  id                  uuid    [pk, default: `gen_random_uuid()`]
  kindergarten_id     uuid    [not null, ref: > kindergartens.id]
  name                varchar [not null]
  capacity            int     [not null, default: 20]
  age_range_min       int     // месяцы
  age_range_max       int
  current_location_id uuid    [ref: > locations.id]
  is_active           boolean [not null, default: true]
  created_at          timestamptz [not null, default: `now()`]
  updated_at          timestamptz [not null, default: `now()`]
}

Table group_mentors {
  id              uuid [pk, default: `gen_random_uuid()`]
  group_id        uuid [not null, ref: > groups.id]
  staff_member_id uuid [not null, ref: > staff_members.id]
  assigned_at     timestamptz [not null, default: `now()`]
  unassigned_at   timestamptz
  is_primary      boolean [not null, default: false]

  // Инварианты (см. SQL-patches внизу файла):
  //  1. Один mentor = ровно одна активная группа
  //     idx_group_mentors_one_active: UNIQUE(staff_member_id) WHERE unassigned_at IS NULL
  //  2. У группы может быть несколько менторов, но РОВНО ОДИН primary
  //     idx_group_mentors_one_primary_per_group:
  //       UNIQUE(group_id) WHERE is_primary = TRUE AND unassigned_at IS NULL
  //  3. Первый назначаемый mentor группы автоматически is_primary=true (логика сервиса)
}

// ─────────────────────────────────────────
// CHILDREN
// ─────────────────────────────────────────

Table children {
  id               uuid         [pk, default: `gen_random_uuid()`]
  kindergarten_id  uuid         [not null, ref: > kindergartens.id]
  iin              char(12)     // nullable: карточка может быть создана до получения ИИН
  full_name        varchar      [not null]
  date_of_birth    date         [not null]
  gender           char(1)
  photo_url        text
  status           child_status [not null, default: 'card_created']
  current_group_id uuid         [ref: > groups.id]
  enrollment_date  date
  archived_at      timestamptz  [note: 'P5/B21 — set to NOW() when status flipped to archived']
  archive_reason   text         [note: 'B21 — reason set when status flipped to archived; required (1..500 chars)']
  medical_notes    text
  allergy_notes    text
  created_at       timestamptz  [not null, default: `now()`]
  updated_at       timestamptz  [not null, default: `now()`]

  indexes {
    (kindergarten_id, iin) [unique, name: 'idx_children_iin_kindergarten'] // partial: WHERE iin IS NOT NULL
    (kindergarten_id, status)
  }
}

Table child_group_history {
  id              uuid [pk, default: `gen_random_uuid()`]
  child_id        uuid [not null, ref: > children.id]
  kindergarten_id uuid [not null, ref: > kindergartens.id]
  from_group_id   uuid [ref: > groups.id]
  to_group_id     uuid [ref: > groups.id]
  transferred_at  timestamptz [not null, default: `now()`]
  transferred_by  uuid [not null, ref: > staff_members.id]
  reason          text
}

Table child_status_history {
  id                       uuid        [pk, default: `gen_random_uuid()`]
  kindergarten_id          uuid        [not null, ref: > kindergartens.id]
  child_id                 uuid        [not null, ref: > children.id]
  previous_status          varchar(32) [not null, note: 'child_status before the transition (e.g. card_created, active, archived)']
  new_status               varchar(32) [not null, note: 'child_status after the transition']
  previous_archive_reason  text        [note: 'captured BEFORE Child.reactivate() clears archive_reason — preserves history for archived→active']
  archive_reason           text        [note: 'archive_reason as of the new state; required when new_status=archived (CHECK constraint)']
  changed_by_user_id       uuid        [not null, ref: > users.id, note: 'users.id of caller (req.user.sub) — matches B13 FK pattern (tariff_assignments.assigned_by, refunds.processed_by)']
  changed_at               timestamptz [not null]
  created_at               timestamptz [not null, default: `now()`]

  indexes {
    (kindergarten_id, changed_at) [name: 'idx_child_status_history_kg_changed_at']
    (child_id, changed_at)        [name: 'idx_child_status_history_child']
  }

  // CHECK chk_valid_transition: (previous_status='active' AND new_status='archived')
  //                          OR (previous_status='archived' AND new_status='active')
  //                          OR (previous_status='card_created' AND new_status='active')
  // CHECK chk_archive_reason_on_archive: new_status<>'archived' OR archive_reason IS NOT NULL
  // FORCE ROW LEVEL SECURITY + tenant_isolation policy + REVOKE TRUNCATE FROM shyraq_app — B22a migration.
}

Table child_guardians {
  id                  uuid             [pk, default: `gen_random_uuid()`]
  kindergarten_id     uuid             [not null, ref: > kindergartens.id]
  child_id            uuid             [not null, ref: > children.id]
  user_id             uuid             [not null, ref: > users.id]
  role                guardian_role    [not null]
  status              guardian_status  [not null, default: 'pending_approval']
  has_approval_rights boolean          [not null, default: false]
  // max 2 users with has_approval_rights = true per child
  approved_by         uuid             [ref: > users.id]
  approved_at         timestamptz
  revoked_by          uuid             [ref: > users.id]
  revoked_at          timestamptz
  can_pickup          boolean          [not null, default: true]
  permissions         jsonb            [not null, default: `'{}'`]
  // Per-guardian permissions overrides (primary управляет для secondary/nanny).
  // Полный whitelist ключей JSONB (все boolean) — см. endpoints.md §4.13 Guardian Permissions Matrix:
  //   toggleable:  view_timeline, view_payments, pay_invoices, view_diagnostics,
  //                view_content, view_cctv, receive_push_non_pickup, create_requests
  //   locked:      prepayment, trusted_people_manage
  // Отсутствующий ключ = default по role.
  // can_pickup и has_approval_rights — отдельные колонки этой таблицы, не часть JSONB.
  // approvals (alias has_approval_rights) — locked, меняется только через §4.2 PATCH .../rights.
  permissions_updated_by uuid          [ref: > users.id]
  permissions_updated_at timestamptz
  created_at          timestamptz      [not null, default: `now()`]
  updated_at          timestamptz      [not null, default: `now()`]
}

// ─────────────────────────────────────────
// ENROLLMENT (LEADS)
// ─────────────────────────────────────────

Table enrollments {
  id                uuid              [pk, default: `gen_random_uuid()`]
  kindergarten_id   uuid              [not null, ref: > kindergartens.id]
  child_id          uuid              [ref: > children.id]
  contact_name      varchar           [not null]
  contact_phone     varchar           [not null]
  child_name        varchar
  child_dob         date
  child_iin         char(12)
  status            enrollment_status [not null, default: 'new']
  source            varchar
  notes             text
  assigned_to       uuid              [ref: > staff_members.id]
  status_changed_at timestamptz       [not null, default: `now()`]
  created_at        timestamptz       [not null, default: `now()`]
  updated_at        timestamptz       [not null, default: `now()`]

  indexes {
    (kindergarten_id, status)
  }
}

Table enrollment_status_log {
  id              uuid              [pk, default: `gen_random_uuid()`]
  enrollment_id   uuid              [not null, ref: > enrollments.id]
  kindergarten_id uuid              [not null, ref: > kindergartens.id]
  from_status     enrollment_status
  to_status       enrollment_status [not null]
  changed_by      uuid              [not null, ref: > staff_members.id]
  comment         text
  created_at      timestamptz       [not null, default: `now()`]
}

// ─────────────────────────────────────────
// ATTENDANCE & TIMELINE
// ─────────────────────────────────────────

Table attendance_events {
  id                uuid                  [pk, default: `gen_random_uuid()`]
  kindergarten_id   uuid                  [not null, ref: > kindergartens.id]
  // FORCE ROW LEVEL SECURITY — defense-in-depth, applies even to table owner; DDL in migration B8AttendanceAndTimeline
  child_id          uuid                  [not null, ref: > children.id]
  event_type        attendance_event_type [not null]
  method            attendance_method     [not null]
  recorded_by       uuid                  [ref: > staff_members.id]
  pickup_user_id    uuid                  [ref: > users.id]
  pickup_request_id uuid                  // ref: > pickup_requests.id — FK added in B11 migration; nullable, written when method='otp_pickup'
  // NOTE: attendance_method enum includes 'otp_pickup' (added in B11 migration via ALTER TYPE attendance_method ADD VALUE 'otp_pickup')
  // 'otp_pickup' is used when a trusted-person pickup is validated via OTP; pickup_request_id references the validated pickup_requests row
  notes             text
  recorded_at       timestamptz           [not null, default: `now()`]
  created_at        timestamptz           [not null, default: `now()`]

  indexes {
    (kindergarten_id, recorded_at)
    (child_id, recorded_at)
  }
}

Table child_daily_status {
  id              uuid                  [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid                  [not null, ref: > kindergartens.id]
  // FORCE ROW LEVEL SECURITY — defense-in-depth, applies even to table owner; DDL in migration B8AttendanceAndTimeline
  child_id        uuid                  [not null, ref: > children.id]
  date            date                  [not null]
  status          child_intraday_status [not null, default: 'absent']
  note            text
  set_by          uuid                  [ref: > staff_members.id]
  updated_at      timestamptz           [not null, default: `now()`]

  indexes {
    (child_id, date) [unique]
    (kindergarten_id, date)
  }
}

Table timeline_entries {
  id              uuid               [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid               [not null, ref: > kindergartens.id]
  // FORCE ROW LEVEL SECURITY — defense-in-depth, applies even to table owner; DDL in migration B8AttendanceAndTimeline
  child_id        uuid               [not null, ref: > children.id]
  entry_type      timeline_entry_type [not null]
  title           varchar
  body            text
  media_urls      text[]
  metadata        jsonb
  recorded_by     uuid               [ref: > staff_members.id]
  entry_time      timestamptz        [not null, default: `now()`]
  created_at      timestamptz        [not null, default: `now()`]

  indexes {
    (child_id, entry_time)
  }
}

// ─────────────────────────────────────────
// SCHEDULE
// ─────────────────────────────────────────

Table schedule_templates {
  id              uuid    [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid    [not null, ref: > kindergartens.id]
  group_id        uuid    [ref: > groups.id]
  // null = шаблон для всего садика; non-null = шаблон конкретной группы
  name            varchar [not null]
  recurrence      varchar [not null, default: 'weekly']
  // only 'weekly' is supported in B7
  is_active       boolean [not null, default: true]
  valid_from      date    [not null]
  valid_until     date
  // null = бессрочный
  created_at      timestamptz [not null, default: `now()`]

  indexes {
    (kindergarten_id, group_id, is_active)
  }
}

Table schedule_template_slots {
  id            uuid    [pk, default: `gen_random_uuid()`]
  template_id   uuid    [not null, ref: > schedule_templates.id]
  day_of_week   varchar [not null]
  // 'mon','tue','wed','thu','fri','sat','sun'
  start_time    time    [not null]
  end_time      time    [not null]
  activity_name varchar [not null]
  location_id   uuid    [ref: > locations.id]
  description   text

  indexes {
    (template_id, day_of_week, start_time) [unique]
    // prevents duplicate slots at the same time within a template
  }
}

Table activity_events {
  id               uuid                   [pk, default: `gen_random_uuid()`]
  kindergarten_id  uuid                   [not null, ref: > kindergartens.id]
  group_id         uuid                   [not null, ref: > groups.id]
  template_slot_id uuid                   [ref: > schedule_template_slots.id]
  // null = ad-hoc event created by staff outside template
  activity_name    varchar                [not null]
  location_id      uuid                   [ref: > locations.id]
  starts_at        timestamptz            [not null]
  ends_at          timestamptz
  status           activity_event_status  [not null, default: 'scheduled']
  // transitions: scheduled→in_progress→completed; scheduled→cancelled; in_progress→cancelled
  created_by       uuid                   [ref: > staff_members.id]
  notes            text
  created_at       timestamptz            [not null, default: `now()`]
  updated_at       timestamptz            [not null, default: `now()`]

  indexes {
    (kindergarten_id, group_id, starts_at)
    (group_id, starts_at)
  }
}

// ─────────────────────────────────────────
// CCTV
// ─────────────────────────────────────────

Table cameras {
  id              uuid    [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid    [not null, ref: > kindergartens.id]
  location_id     uuid    [not null, ref: > locations.id]
  name            varchar [not null]
  stream_url      text    [not null] // rtsp://mediamtx:8554/cam-{id}
  is_active       boolean [not null, default: true]
  created_at      timestamptz [not null, default: `now()`]

  indexes {
    location_id
  }
}

// ─────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────

// B13 — FORCE ROW LEVEL SECURITY + tenant_isolation policy on kindergarten_id
Table payment_accounts {
  id              uuid         [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid         [not null, ref: > kindergartens.id]
  child_id        uuid         [not null, ref: > children.id]
  balance         decimal(12,2) [not null, default: 0]
  // positive = кредит, negative = задолженность
  created_at      timestamptz  [not null, default: `now()`]
  updated_at      timestamptz  [not null, default: `now()`]

  indexes {
    (kindergarten_id, child_id) [unique]
  }

  Note: 'FORCE ROW LEVEL SECURITY — tenant_isolation policy: kindergarten_id = current_setting(app.kindergarten_id)::uuid OR current_setting(app.bypass_rls) = true'
}

// B13 — FORCE ROW LEVEL SECURITY + tenant_isolation policy on kindergarten_id
// State machine: pending → {partial, paid, overdue, refunded, cancelled}
Table invoices {
  id                    uuid           [pk, default: `gen_random_uuid()`]
  kindergarten_id       uuid           [not null, ref: > kindergartens.id]
  child_id              uuid           [not null, ref: > children.id]
  payment_account_id    uuid           [not null, ref: > payment_accounts.id]
  tariff_plan_id        uuid           [ref: > tariff_plans.id] // откуда сгенерирован
  invoice_type          payment_type   [not null]
  period_start          date
  period_end            date
  amount_due            decimal(12,2)  [not null]
  discount_pct          decimal(5,2)   [not null, default: 0]
  discount_reason       varchar
  amount_after_discount decimal(12,2)  [not null]
  status                payment_status [not null, default: 'pending']
  due_date              date           [not null]
  description           text
  prorated_for_days     int            // null если полный период
  created_at            timestamptz    [not null, default: `now()`]
  updated_at            timestamptz    [not null, default: `now()`]

  indexes {
    child_id
    (kindergarten_id, due_date)
    (kindergarten_id, status)
  }

  Note: 'FORCE ROW LEVEL SECURITY — tenant_isolation policy: kindergarten_id = current_setting(app.kindergarten_id)::uuid OR current_setting(app.bypass_rls) = true'
}

// B13 — FORCE ROW LEVEL SECURITY + tenant_isolation policy on kindergarten_id
// State machine (payment_status_v2): initiated → {processing, completed, failed, refunded}
Table payments {
  id               uuid              [pk, default: `gen_random_uuid()`]
  kindergarten_id  uuid              [not null, ref: > kindergartens.id]
  invoice_id       uuid              [not null, ref: > invoices.id]
  child_id         uuid              [not null, ref: > children.id]
  payer_user_id    uuid              [ref: > users.id]
  amount           decimal(12,2)     [not null]
  provider         varchar           [not null]
  // CHECK provider IN ('mock','halyk_epay','kaspi_pay','tiptoppay','freedom_pay','cash')
  // 'mock'        — MockPaymentProvider (B13 default, dev/CI/demo)
  // 'halyk_epay'  — Halyk Bank ePay (Phase B — B14)
  // 'kaspi_pay'   — Kaspi Pay API (Kaspi.kz)
  // 'tiptoppay'   — TipTopPay (любые карты)
  // 'freedom_pay' — Freedom Pay (любые карты)
  // 'cash'        — наличные (offline подтверждение)
  provider_txn_id  varchar
  idempotency_key  varchar           [unique, not null]
  status           payment_status_v2 [not null, default: 'initiated']
  provider_payload jsonb
  paid_at          timestamptz
  refund_id        uuid              [ref: > refunds.id] // если был возврат
  created_at       timestamptz       [not null, default: `now()`]
  updated_at       timestamptz       [not null, default: `now()`]

  indexes {
    (provider, provider_txn_id)
    (kindergarten_id, status)
  }

  Note: 'FORCE ROW LEVEL SECURITY — tenant_isolation policy: kindergarten_id = current_setting(app.kindergarten_id)::uuid OR current_setting(app.bypass_rls) = true'
}

// ─────────────────────────────────────────
// KASPI PAY (B24 — основной платёжный провайдер, неофициальный клиент)
// ─────────────────────────────────────────
// Kaspi Pay подключается как per-tenant адаптер PaymentProviderPort
// (provider='kaspi_pay'). В отличие от Mock/Halyk (singleton), у каждого
// садика своя кассирская сессия Kaspi → креды хранятся per-tenant и
// резолвятся в момент вызова. Источник реализации — реверс-инжиниринг
// iOS-приложения Kaspi Pay (см. kaspi_pay_test/HANDOFF.md).

// ENUM kaspi_session_status: pending | active | expired | revoked
// (varchar в DBML; TypeORM-миграция создаёт PG ENUM kaspi_session_status)

// B24 — FORCE ROW LEVEL SECURITY + tenant_isolation policy on kindergarten_id
// Одна запись на садик (UNIQUE kindergarten_id) = один подключённый
// кассирский аккаунт Kaspi. Всё чувствительное — зашифровано at-rest
// (AES-256-GCM, CryptoCipherAdapter, ключ env KASPI_ENCRYPTION_KEY).
Table kaspi_merchant_session {
  id                   uuid    [pk, default: `gen_random_uuid()`]
  kindergarten_id      uuid    [not null, unique, ref: > kindergartens.id] // один аккаунт на садик
  connected_by_user_id uuid    [not null, ref: > users.id]                 // админ, подключивший Kaspi
  status               varchar [not null, default: 'pending']
  // kaspi_session_status: 'pending' → 'active' → {'expired','revoked'}
  cashier_phone        varchar // номер кассира (отображение / реконнект)
  kaspi_profile_id     varchar // profileId из org-context
  kaspi_org_id         varchar // organizationId
  org_name             varchar // имя организации (отображение)
  token_sn             text    // tokenSN сессии (сам по себе не секрет, храним вместе)
  vtoken_secret_enc    text    // ENC: ECDH-секрет для TOTP-MAC (X-Kb-TokenSnMac)
  device_keypair_enc   text    // ENC: ECDSA-приватник устройства (X-Sign)
  ecdh_keypair_enc     text    // ENC: ECDH-ключ с finish (нужен для /refresh SignInLite)
  device_id            varchar // отпечаток устройства — СВОЙ на садик (не глобальный)
  install_id           varchar
  pin_hash             varchar
  last_checked_at      timestamptz // когда поллер/health-check последний раз пинговал сессию
  created_at           timestamptz [not null, default: `now()`]
  updated_at           timestamptz [not null, default: `now()`]

  indexes {
    (kindergarten_id, status)
  }

  Note: 'FORCE ROW LEVEL SECURITY — tenant_isolation policy: kindergarten_id = current_setting(app.kindergarten_id)::uuid OR current_setting(app.bypass_rls) = true. UNIQUE(kindergarten_id) — один кассирский аккаунт на садик.'
}

// B24 — НЕ tenant-scoped, БЕЗ RLS, single-row. Глобальный конфиг Kaspi,
// редактируемый суперадмином (saas-контроллер) без передеплоя.
// Решает версионный гейт: Kaspi отдаёт OldVersionToUpdate по полю app_build
// (строка app_version игнорируется — эмпирически, floor сейчас = 1071).
// При блокировке суперадмин поднимает app_build и все садики чинятся.
Table kaspi_global_config {
  id            int         [pk, default: 1]   // single-row guard: CHECK (id = 1)
  app_version   varchar     [not null]         // для UA-строк / косметики
  app_build     varchar     [not null]         // ⚠️ ключевое поле гейта (app_build >= floor)
  platform_ver  varchar     [not null]         // напр. '18.5'
  model         varchar     [not null]         // напр. 'iPhone17,3'
  brand         varchar     [not null]         // напр. 'Apple'
  ua_native     varchar     [not null]         // User-Agent нативного клиента
  ua_browser    varchar     [not null]         // User-Agent webview
  entrance_url  varchar     [not null]         // https://entrance-pay.kaspi.kz
  mtoken_url    varchar     [not null]         // https://mtoken.kaspi.kz
  qrpay_url     varchar     [not null]         // https://qrpay.kaspi.kz
  updated_by    uuid        [ref: > users.id]  // суперадмин-аудит
  updated_at    timestamptz [not null, default: `now()`]
}

// ─────────────────────────────────────────
// PARENT REQUESTS
// ─────────────────────────────────────────

// B12 — FORCE ROW LEVEL SECURITY + tenant_isolation policy on kindergarten_id
Table parent_requests {
  id                  uuid                  [pk, default: `gen_random_uuid()`]
  kindergarten_id     uuid                  [not null, ref: > kindergartens.id]
  child_id            uuid                  [not null, ref: > children.id]
  requester_user_id   uuid                  [not null, ref: > users.id]        // approved guardian с permissions.create_requests
  request_type        parent_request_type   [not null]
  status              parent_request_status [not null, default: 'pending']
  date_from           date                                                      // vacation: start; late_pickup: дата
  date_to             date                                                      // vacation: end (inclusive); null для остальных
  details             jsonb                 [not null, default: `{}`]
  // per-type payload:
  //   trusted_person: {full_name, phone, iin?, relation, photo_url?, is_one_time?, create_pickup_request?, trusted_person_id?}
  //   day_off:        {weekend_dates: ['YYYY-MM-DD', ...] — 1-2 даты, каждая Сб/Вс; comment?}
  //   vacation:       {comment?}
  //   late_pickup:    {expected_time: 'HH:MM', tariff_amount_kzt?, comment?}
  //   open_request:   {subject, message, attachments?}
  recipient_type      varchar(20)                                               // 'admin' | 'mentor' | 'specialist'
  recipient_staff_id  uuid                  [ref: > staff_members.id]
  reviewed_by         uuid                  [ref: > staff_members.id]
  reviewed_at         timestamptz
  review_note         text
  invoice_id          uuid                  // nullable — FK → invoices.id ON DELETE SET NULL (добавлен в B13 ALTER)
  // B13 adds: ALTER TABLE parent_requests ADD CONSTRAINT fk_parent_requests_invoice_id FOREIGN KEY (invoice_id) REFERENCES invoices(id) ON DELETE SET NULL
  created_at          timestamptz           [not null, default: `now()`]
  updated_at          timestamptz           [not null, default: `now()`]

  indexes {
    (kindergarten_id, status)
    (child_id, created_at DESC)
    (recipient_staff_id, status)    // WHERE recipient_staff_id IS NOT NULL (partial, добавляется в миграции)
    (requester_user_id, created_at DESC)
  }
}

// B11 — FORCE ROW LEVEL SECURITY, tenant_isolation policy on kindergarten_id
// ENUM pickup_request_status: otp_sent | validated | expired | cancelled
// (represented as varchar in DBML; TypeORM migration creates PG ENUM pickup_request_status)
Table pickup_requests {
  id                   uuid        [pk, default: `gen_random_uuid()`]
  kindergarten_id      uuid        [not null, ref: > kindergartens.id]
  child_id             uuid        [not null, ref: > children.id]
  requested_by_user_id uuid        [not null, ref: > users.id]
  trusted_person_id    uuid        [ref: > trusted_people.id] // nullable — для ad-hoc (без whitelist)
  trusted_person_phone varchar(20) [not null] // snapshot-копия (denormalization; даже если trusted_person_id non-null)
  trusted_person_name  text        [not null] // snapshot-копия
  trusted_person_iin   char(12)               // snapshot-копия, nullable
  otp_ref              varchar     [not null]  // Redis key: 'otp:pickup:{requestId}'
  status               varchar     [not null, default: 'otp_sent']
  // pickup_request_status ENUM: 'otp_sent' → 'validated' | 'expired' | 'cancelled'
  validated_by         uuid        [ref: > staff_members.id]   // nullable
  validated_at         timestamptz                              // nullable
  attendance_event_id  uuid        [ref: > attendance_events.id] // nullable; written after check-out created
  parent_request_id    uuid        [ref: > parent_requests.id]   // nullable — B12 parent_requests link
  expires_at           timestamptz [not null] // = created_at + 1800s (OTP TTL)
  created_at           timestamptz [not null, default: `now()`]

  indexes {
    (kindergarten_id, status)         // list by tenant+status (staff view)
    (child_id, created_at DESC)       // per-child history
  }
  // RLS: FORCE ROW LEVEL SECURITY — tenant_isolation policy:
  //   kindergarten_id = current_setting('app.kindergarten_id')::uuid
  //   OR current_setting('app.bypass_rls') = 'true'
}

// ─────────────────────────────────────────
// DIAGNOSTICS & PROGRESS
// ─────────────────────────────────────────

Table diagnostic_templates {
  id              uuid    [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid    [not null, ref: > kindergartens.id]
  specialist_type varchar [not null]
  name            varchar [not null]
  description     text
  version         int     [not null, default: 1]
  is_active       boolean [not null, default: true]
  schema          jsonb   [not null]
  // { sections: [{ title, fields: [{ key, label, type, required, options, min, max }] }] }
  // type: text | number | boolean | select | multiselect | date | scale
  created_by      uuid    [not null, ref: > staff_members.id]
  created_at      timestamptz [not null, default: `now()`]
  updated_at      timestamptz [not null, default: `now()`]

  indexes {
    (kindergarten_id, specialist_type)
  }
}

Table diagnostic_entries {
  id                        uuid        [pk, default: `gen_random_uuid()`]
  kindergarten_id           uuid        [not null, ref: > kindergartens.id]
  child_id                  uuid        [not null, ref: > children.id]
  template_id               uuid        [not null, ref: > diagnostic_templates.id]
  specialist_id             uuid        [not null, ref: > staff_members.id]
  assessment_date           date        [not null]
  data                      jsonb       [not null] // ответы по ключам из template.schema
  summary                   text
  recommendations           text
  attachments               text[]
  last_modified_by_user_id  uuid        [ref: > users.id, note: 'B22a: stamped on every PATCH incl. admin-override path; surfaces audit trail for admin bypass of assertAuthoredBy']
  last_modified_at          timestamptz [note: 'B22a: stamped on every PATCH together with last_modified_by_user_id']
  created_at                timestamptz [not null, default: `now()`]
  updated_at                timestamptz [not null, default: `now()`]

  indexes {
    (child_id, assessment_date)
    (kindergarten_id, assessment_date)
  }
}

Table progress_notes {
  id                        uuid        [pk, default: `gen_random_uuid()`]
  kindergarten_id           uuid        [not null, ref: > kindergartens.id]
  child_id                  uuid        [not null, ref: > children.id]
  mentor_id                 uuid        [not null, ref: > staff_members.id]
  body                      text        [not null]
  media_urls                text[]
  noted_at                  timestamptz [not null, default: `now()`]
  last_modified_by_user_id  uuid        [ref: > users.id, note: 'B22a: stamped on every PATCH incl. admin-override path']
  last_modified_at          timestamptz [note: 'B22a: stamped on every PATCH together with last_modified_by_user_id']
  created_at                timestamptz [not null, default: `now()`]

  indexes {
    (child_id, noted_at)
  }
}

// ─────────────────────────────────────────
// CONTENT
// ─────────────────────────────────────────

Table content_posts {
  id              uuid               [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid               [not null, ref: > kindergartens.id]
  content_type    content_type       [not null]
  target_type     content_target_type [not null, default: 'all']
  target_group_id uuid               [ref: > groups.id]
  target_child_id uuid               [ref: > children.id]
  title           varchar            // legacy, fallback
  body            text               // legacy, fallback
  title_i18n      jsonb              // {ru: "...", kz: "..."}
  body_i18n       jsonb              // {ru: "...", kz: "..."}
  media_urls      text[]
  metadata        jsonb
  // qundylyq:  { month, theme }
  // birthday:  { child_id, age }
  scheduled_for   timestamptz        // отложенная публикация
  published_at    timestamptz
  expires_at      timestamptz
  status          varchar            [not null, default: 'draft']
  // 'draft', 'scheduled', 'published'
  created_by      uuid               [ref: > staff_members.id]
  created_at      timestamptz        [not null, default: `now()`]
  updated_at      timestamptz        [not null, default: `now()`]

  indexes {
    (kindergarten_id, published_at)
  }
}

Table group_stories {
  id              uuid    [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid    [not null, ref: > kindergartens.id]
  group_id        uuid    [not null, ref: > groups.id]
  created_by      uuid    [not null, ref: > staff_members.id]
  media_url       text    [not null]
  media_type      varchar [not null] // 'image' | 'video'
  caption         text
  views           int     [not null, default: 0]
  expires_at      timestamptz [not null] // created_at + 24h
  created_at      timestamptz [not null, default: `now()`]

  indexes {
    expires_at
    (group_id, expires_at)
  }
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

Table push_tokens {
  id           uuid         [pk, default: `gen_random_uuid()`]
  user_id      uuid         [not null, ref: > users.id]
  token        varchar(512) [not null]
  platform     varchar(16)  [not null] // 'ios' | 'android' | 'web'
  app_version  varchar(32)
  device_id    varchar(128)
  last_seen_at timestamptz  [not null, default: `now()`]
  created_at   timestamptz  [not null, default: `now()`]

  indexes {
    // (platform, token) is globally unique — same token under a different
    // user is interpreted as ownership transfer (shared physical device).
    // See migration B9PushTokenPlatformUnique.
    (platform, token) [unique]
    user_id
  }
}

Table notifications {
  id              uuid        [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid        [not null, ref: > kindergartens.id]
  user_id         uuid        [not null, ref: > users.id]
  event_key       varchar(64) [not null] // см. "Notification event catalog" в architecture.md §6.5
  title_i18n      jsonb       [not null] // {ru, kk, en}
  body_i18n       jsonb       [not null] // {ru, kk, en}
  data            jsonb       [not null, default: `'{}'::jsonb`]
  read_at         timestamptz
  created_at      timestamptz [not null, default: `now()`]

  indexes {
    (kindergarten_id, user_id, created_at) // idx_notifications_kg_user_created
    (kindergarten_id, user_id, created_at) [name: 'idx_notifications_unread'] // partial WHERE read_at IS NULL
  }
  // RLS: FORCE ROW LEVEL SECURITY, policy tenant_isolation on kindergarten_id
}

Table notification_preferences {
  id             uuid        [pk, default: `gen_random_uuid()`]
  user_id        uuid        [not null, ref: > users.id]
  event_key      varchar(64) [not null]
  push_enabled   boolean     [not null, default: true]
  in_app_enabled boolean     [not null, default: true]
  updated_at     timestamptz [not null, default: `now()`]

  indexes {
    (user_id, event_key) [unique]
  }
  // No RLS — global per-user per-event; accessed cross-tenant by the outbox worker.
}

// Transactional Outbox — written inside the same business TX that produces the
// domain event. Worker polls pending rows (FOR UPDATE SKIP LOCKED) and
// fan-outs to push + WS. RLS-scoped: FORCE ROW LEVEL SECURITY, policy
// kindergarten_id = current_setting('app.kindergarten_id')::uuid
//   OR current_setting('app.bypass_rls')='true'.
Table notification_outbox {
  id              uuid        [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid        [not null, ref: > kindergartens.id]
  event_key       varchar(64) [not null] // e.g. 'attendance.checkin'
  payload         jsonb       [not null] // domain event payload: recipient hints + denormalized data
  status          varchar(16) [not null, default: 'pending'] // 'pending' | 'dispatched' | 'failed'
  attempts        int         [not null, default: 0]
  next_retry_at   timestamptz [not null, default: `now()`]
  created_at      timestamptz [not null, default: `now()`]
  dispatched_at   timestamptz
  failed_reason   text

  indexes {
    (status, next_retry_at) [name: 'idx_outbox_pending']
  }
}

// ─────────────────────────────────────────
// BILLING — TARIFFS, HOLIDAYS, REFUNDS, LINE ITEMS
// ─────────────────────────────────────────

// B13 — FORCE ROW LEVEL SECURITY + tenant_isolation policy on kindergarten_id
Table tariff_plans {
  id              uuid [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid [not null, ref: > kindergartens.id]
  name            varchar [not null]
  description     jsonb // {ru: "...", kz: "..."}
  tariff_type     tariff_type [not null]
  amount          decimal(12,2) [not null]
  currency        varchar(3) [not null, default: 'KZT']
  applies_to      varchar [not null, default: 'child']
  // 'child', 'group', 'age_range'
  group_id        uuid [ref: > groups.id]
  age_min_months  int
  age_max_months  int
  is_active       boolean [not null, default: true]
  valid_from      date [not null]
  valid_until     date
  discount_rules  jsonb
  // { sibling_discount_pct, prepay_3m_pct, prepay_6m_pct, prepay_12m_pct, prepay_24m_pct?, benefit_category }
  // prepay_24m_pct — опциональный долгий горизонт предоплаты (настраивается админом).
  created_at      timestamptz [not null, default: `now()`]
  updated_at      timestamptz [not null, default: `now()`]

  indexes {
    (kindergarten_id, is_active)
    (kindergarten_id, tariff_type)
  }

  Note: 'FORCE ROW LEVEL SECURITY — tenant_isolation policy: kindergarten_id = current_setting(app.kindergarten_id)::uuid OR current_setting(app.bypass_rls) = true'
}

// B13 — FORCE ROW LEVEL SECURITY + tenant_isolation policy on kindergarten_id
Table tariff_assignments {
  id              uuid [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid [not null, ref: > kindergartens.id]
  child_id        uuid [not null, ref: > children.id]
  tariff_plan_id  uuid [not null, ref: > tariff_plans.id]
  custom_amount   decimal(12,2) // переопределение (льгота)
  custom_reason   varchar
  valid_from      date [not null]
  valid_until     date
  assigned_by     uuid [ref: > staff_members.id]
  created_at      timestamptz [not null, default: `now()`]

  indexes {
    (child_id, valid_from)
  }

  Note: 'FORCE ROW LEVEL SECURITY — tenant_isolation policy: kindergarten_id = current_setting(app.kindergarten_id)::uuid OR current_setting(app.bypass_rls) = true'
}

// B13 — FORCE ROW LEVEL SECURITY + tenant_isolation policy on kindergarten_id
Table invoice_line_items {
  id              uuid [pk, default: `gen_random_uuid()`]
  invoice_id      uuid [not null, ref: > invoices.id]
  kindergarten_id uuid [not null, ref: > kindergartens.id]
  description     varchar [not null]
  tariff_plan_id  uuid [ref: > tariff_plans.id]
  quantity        decimal(10,2) [not null, default: 1]
  unit_price      decimal(12,2) [not null]
  line_total      decimal(12,2) [not null]
  created_at      timestamptz [not null, default: `now()`]

  Note: 'FORCE ROW LEVEL SECURITY — tenant_isolation policy: kindergarten_id = current_setting(app.kindergarten_id)::uuid OR current_setting(app.bypass_rls) = true'
}

// B13 — FORCE ROW LEVEL SECURITY + tenant_isolation policy on kindergarten_id
Table kindergarten_holidays {
  id              uuid [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid [not null, ref: > kindergartens.id]
  date            date [not null]
  name            jsonb [not null] // {ru: "...", kz: "..."} — multilingual
  is_billable     boolean [not null, default: false]
  created_at      timestamptz [not null, default: `now()`]

  indexes {
    (kindergarten_id, date) [unique]
  }

  Note: 'FORCE ROW LEVEL SECURITY — tenant_isolation policy: kindergarten_id = current_setting(app.kindergarten_id)::uuid OR current_setting(app.bypass_rls) = true'
}

// B13 — FORCE ROW LEVEL SECURITY + tenant_isolation policy on kindergarten_id
// State machine: pending → {approved → processed, rejected}
Table refunds {
  id              uuid [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid [not null, ref: > kindergartens.id]
  payment_id      uuid [not null, ref: > payments.id]
  invoice_id      uuid [ref: > invoices.id]
  amount          decimal(12,2) [not null]
  reason          varchar [not null]
  status          refund_status [not null, default: 'pending']
  processed_by    uuid [ref: > staff_members.id]
  provider_ref    varchar
  created_at      timestamptz [not null, default: `now()`]
  updated_at      timestamptz [not null, default: `now()`]

  Note: 'FORCE ROW LEVEL SECURITY — tenant_isolation policy: kindergarten_id = current_setting(app.kindergarten_id)::uuid OR current_setting(app.bypass_rls) = true'
}

// ─────────────────────────────────────────
// FISCAL (ОФД РК)
// ─────────────────────────────────────────

Table fiscal_receipts {
  id              uuid [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid [not null, ref: > kindergartens.id]
  payment_id      uuid [not null, ref: > payments.id]
  provider        varchar [not null]  // 'kassa24', 'rekassa', 'webkassa'
  kkm_id          varchar
  fiscal_sign     varchar
  receipt_number  varchar
  total_amount    decimal(12,2) [not null]
  vat_amount      decimal(12,2)
  qr_url          text
  ofd_payload     jsonb
  status          fiscal_receipt_status [not null, default: 'pending']
  issued_at       timestamptz
  retry_count     int [not null, default: 0]
  error_message   text
  created_at      timestamptz [not null, default: `now()`]
  updated_at      timestamptz [not null, default: `now()`]

  indexes {
    payment_id
    (kindergarten_id, status)
    (provider, fiscal_sign)
  }
}

// ─────────────────────────────────────────
// FACE ID (InsightFace)
// ─────────────────────────────────────────

Table face_profiles {
  id                    uuid [pk, default: `gen_random_uuid()`]
  kindergarten_id       uuid [not null, ref: > kindergartens.id]
  subject_type          face_subject_type [not null]
  subject_id            uuid [not null]
  // Полиморф: children.id | users.id | staff_members.id
  provider              varchar [not null, default: 'insightface']
  external_id           varchar
  embedding_vector_ref  varchar
  photo_url             text [not null]
  is_active             boolean [not null, default: true]
  enrolled_by           uuid [ref: > staff_members.id]
  enrolled_at           timestamptz [not null, default: `now()`]
  created_at            timestamptz [not null, default: `now()`]

  indexes {
    (kindergarten_id, subject_type, subject_id)
    external_id [unique]
  }
}

Table face_recognition_events {
  id                   uuid [pk, default: `gen_random_uuid()`]
  kindergarten_id      uuid [not null, ref: > kindergartens.id]
  camera_device_id     varchar [not null]
  face_profile_id      uuid [ref: > face_profiles.id]
  confidence           decimal(5,2)      // 0..100 match score
  spoof_score          decimal(5,2)      // 0..100 liveness (выше = живее)
  liveness_method      liveness_method [not null, default: 'passive']
  event_type           face_event_type [not null]
  matched_photo_url    text
  attendance_event_id  uuid [ref: > attendance_events.id]
  status               face_event_status [not null, default: 'matched']
  created_at           timestamptz [not null, default: `now()`]

  indexes {
    (kindergarten_id, created_at)
    face_profile_id
  }
}

// Фиксация consent на биометрию (обязательно по закону РК перед enrollment Face ID).
// Захват происходит офлайн в садике: персонал отмечает подпись родителя/опекуна
// (или самого сотрудника — при enrollment его профиля).
Table face_enrollment_consents {
  id                    uuid [pk, default: `gen_random_uuid()`]
  kindergarten_id       uuid [not null, ref: > kindergartens.id]
  subject_type          face_subject_type [not null]
  subject_id            uuid [not null]
  // Полиморф: children.id | users.id | staff_members.id (как в face_profiles)
  captured_by_staff_id  uuid [not null, ref: > staff_members.id]
  captured_at           timestamptz [not null, default: `now()`]
  signature_url         text  // скан/фото подписанного согласия, S3 key
  face_profile_id       uuid [ref: > face_profiles.id] // связка после enrollment
  revoked_at            timestamptz
  revoke_reason         text
  created_at            timestamptz [not null, default: `now()`]

  indexes {
    (kindergarten_id, subject_type, subject_id)
  }
}

// Несколько embedding'ов на один face_profile (video enrollment 5-10 кадров)
Table face_embeddings {
  id              uuid [pk, default: `gen_random_uuid()`]
  face_profile_id uuid [not null, ref: > face_profiles.id]
  vector_ref      varchar [not null] // Qdrant point ID или pgvector row id
  frame_index     int [not null, default: 0]
  quality_score   decimal(5,2) // качество кадра (для приоритета)
  captured_at     timestamptz [not null, default: `now()`]

  indexes {
    face_profile_id
  }
}

// ─────────────────────────────────────────
// MEAL PLANS (структурированное меню)
// ─────────────────────────────────────────

Table meal_plans {
  id              uuid    [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid    [not null, ref: > kindergartens.id]
  date            date    [not null]
  group_id        uuid    [ref: > groups.id]
  // null = общее меню садика; non-null = меню конкретной группы
  is_published    boolean [not null, default: true]
  notes           jsonb
  // локализованные заметки {ru, kz}
  source          varchar [not null, default: 'manual']
  // 'manual' | 'auto_copied_from_previous_week'
  copied_from     uuid    [ref: > meal_plans.id]
  created_by      uuid    [ref: > staff_members.id]
  created_at      timestamptz [not null, default: `now()`]
  updated_at      timestamptz [not null, default: `now()`]

  indexes {
    (kindergarten_id, date)
    (group_id, date)
    (kindergarten_id, date, group_id) [unique]
    // one meal_plan per (date, group_id) per tenant; group_id=NULL = kindergarten-wide
    // NOTE: in PostgreSQL, NULL values are not considered equal in unique indexes,
    // so two rows with group_id=NULL on the same date would not conflict at DB level.
    // Enforce uniqueness for group_id=NULL via partial unique index in migration:
    // CREATE UNIQUE INDEX uq_meal_plans_date_kg ON meal_plans (kindergarten_id, date) WHERE group_id IS NULL;
    // CREATE UNIQUE INDEX uq_meal_plans_date_group ON meal_plans (kindergarten_id, date, group_id) WHERE group_id IS NOT NULL;
  }
}

Table meal_items {
  id              uuid [pk, default: `gen_random_uuid()`]
  meal_plan_id    uuid [not null, ref: > meal_plans.id]
  meal_type       meal_type [not null]
  dish_name       jsonb [not null] // {ru, kz}
  description     jsonb
  allergens       text[]
  photo_url       text
  calories        int
  position        int [not null, default: 0]

  indexes {
    meal_plan_id
  }
}

// ─────────────────────────────────────────
// SCHEDULE — помощник для недели
// ─────────────────────────────────────────

Table schedule_week_snapshots {
  id              uuid [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid [not null, ref: > kindergartens.id]
  group_id        uuid [not null, ref: > groups.id]
  week_start_date date [not null] // понедельник
  source          varchar [not null]
  // 'manual' | 'auto_copied_from_previous_week'
  copied_from     uuid [ref: > schedule_week_snapshots.id]
  created_at      timestamptz [not null, default: `now()`]

  indexes {
    (group_id, week_start_date) [unique]
  }
}

// ─────────────────────────────────────────
// TRUSTED PEOPLE (переиспользуемый whitelist)
// B11 — FORCE ROW LEVEL SECURITY, tenant_isolation policy on kindergarten_id
// ─────────────────────────────────────────

Table trusted_people {
  id               uuid [pk, default: `gen_random_uuid()`]
  kindergarten_id  uuid [not null, ref: > kindergartens.id, note: 'ON DELETE CASCADE']
  child_id         uuid [not null, ref: > children.id, note: 'ON DELETE CASCADE']
  added_by_user_id uuid [not null, ref: > users.id]
  full_name        text [not null]
  phone            varchar(20) [not null]
  iin              char(12)    // nullable
  relation         text
  photo_url        text
  is_active        boolean [not null, default: true]
  is_one_time      boolean [not null, default: false]
  // true = деактивируется автоматически после первого успешного pickup
  used_at          timestamptz // null → not used yet; set when is_one_time pickup completes
  created_at       timestamptz [not null, default: `now()`]
  revoked_at       timestamptz // null → active; set on manual revoke

  indexes {
    (child_id, is_active)
    (kindergarten_id, child_id)  // for per-tenant child whitelist listing
  }
  // RLS: FORCE ROW LEVEL SECURITY — tenant_isolation policy:
  //   kindergarten_id = current_setting('app.kindergarten_id')::uuid
  //   OR current_setting('app.bypass_rls') = 'true'
}

// ─────────────────────────────────────────
// PARENT REQUEST — треды ответов (не чат!)
// ─────────────────────────────────────────

// B12 — FORCE ROW LEVEL SECURITY + tenant_isolation policy on kindergarten_id
Table parent_request_messages {
  id                uuid [pk, default: `gen_random_uuid()`]
  kindergarten_id   uuid [not null, ref: > kindergartens.id]
  parent_request_id uuid [not null, ref: > parent_requests.id, delete: cascade]
  author_user_id    uuid [ref: > users.id]          // parent author (nullable)
  author_staff_id   uuid [ref: > staff_members.id]  // staff author (nullable)
  // CHECK: exactly one of author_user_id / author_staff_id is NOT NULL
  // (author_user_id IS NOT NULL)::int + (author_staff_id IS NOT NULL)::int = 1
  body              text [not null]
  attachments       text[]
  created_at        timestamptz [not null, default: `now()`]

  indexes {
    (parent_request_id, created_at ASC)
  }
}

// ─────────────────────────────────────────
// SAAS-LEVEL (SuperAdmin)
// ─────────────────────────────────────────

Table saas_users {
  id            uuid [pk, default: `gen_random_uuid()`]
  email         varchar [unique, not null]
  phone         varchar(20) [unique]
  full_name     varchar [not null]
  password_hash varchar [not null]
  role          saas_user_role [not null]
  is_active     boolean [not null, default: true]
  last_login_at timestamptz
  created_at    timestamptz [not null, default: `now()`]
}

// Зеркало `refresh_tokens`, но FK на `saas_users` (не `users`).
// Два identity-домена полностью разделены: Parent/Staff OTP-flow пишет в
// `refresh_tokens`, SuperAdmin email+password-flow пишет сюда. Никакого
// polymorphism. Токены opaque (sha256(raw)), TTL = REFRESH_TOKEN_TTL_DAYS.
Table saas_refresh_tokens {
  id            uuid        [pk, default: `gen_random_uuid()`]
  saas_user_id  uuid        [not null, ref: > saas_users.id]
  token_hash    varchar     [unique, not null]
  device_id     varchar
  ip_address    varchar
  expires_at    timestamptz [not null]
  revoked_at    timestamptz
  created_at    timestamptz [not null, default: `now()`]

  indexes {
    saas_user_id
  }
}

Table saas_subscriptions {
  id              uuid [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid [not null, ref: > kindergartens.id]
  plan_code       varchar [not null]
  status          subscription_status [not null]
  billing_period  varchar [not null] // 'monthly', 'yearly'
  amount          decimal(12,2) [not null]
  started_at      date [not null]
  next_billing_at date
  cancelled_at    timestamptz
  created_at      timestamptz [not null, default: `now()`]
  updated_at      timestamptz [not null, default: `now()`]
}

Table feature_flags {
  id              uuid [pk, default: `gen_random_uuid()`]
  kindergarten_id uuid [ref: > kindergartens.id] // null = глобальный
  key             varchar [not null]
  value           jsonb [not null]
  created_at      timestamptz [not null, default: `now()`]

  indexes {
    (kindergarten_id, key) [unique]
  }
}

// ─────────────────────────────────────────
// USER QR TOKENS (identity QR, refreshable 24h)
// NO RLS — cross-tenant by design: one QR per user
// regardless of how many kindergartens their children
// are enrolled in. kindergarten_id is nullable.
// ─────────────────────────────────────────

Table user_qr_tokens {
  id              uuid [pk, default: `gen_random_uuid()`]
  user_id         uuid [not null, ref: > users.id]
  kindergarten_id uuid [null, ref: > kindergartens.id]
  // null для родителей с детьми в нескольких садиках — QR глобален
  purpose         qr_purpose [not null, default: 'identity']
  token_hash      varchar(64) [unique, not null] // SHA-256 hex of opaque token; plaintext lives only in Redis qr:token:{plaintext}
  issued_at       timestamptz [not null, default: `now()`]
  expires_at      timestamptz [not null]         // issued_at + 24h
  revoked_at      timestamptz                    // при refresh старый ревокируется
  last_scanned_at timestamptz

  // Инварианты:
  //  1. Один активный токен на (user_id, purpose)
  //     idx_user_qr_tokens_one_active: UNIQUE(user_id, purpose) WHERE revoked_at IS NULL
  //     Без NOW() predicate (PG отвергает non-IMMUTABLE). Active-uniqueness
  //     enforced в коде via revoke-old-then-insert-new TX.

  indexes {
    (user_id, purpose)
    (expires_at)
    token_hash [unique]
  }
}

// ─────────────────────────────────────────
// CUSTOM DISCOUNTS (праздничные и спец. скидки)
// ─────────────────────────────────────────

Table custom_discounts {
  id                     uuid [pk, default: `gen_random_uuid()`]
  kindergarten_id        uuid [not null, ref: > kindergartens.id]
  name                   jsonb [not null]  // {ru, kz}
  description            jsonb
  discount_type          custom_discount_type [not null]
  amount                 decimal(10,2) [not null]
  // discount_type='percentage' → 0..100
  // discount_type='fixed_amount' → сумма в KZT

  // Условия применения (композитный JSONB)
  conditions             jsonb [not null, default: `{}`]
  // Примеры:
  // { type: "prepayment_months", min_months: 24 }
  // { type: "siblings_count", min: 3 }
  // { type: "age_range", min_months: 12, max_months: 36 }
  // { type: "benefit_category", values: ["disability","single_parent"] }
  // { type: "payment_method", providers: ["kaspi_pay"] }
  // { type: "early_payment", before_day_of_month: 5 }
  // { type: "birthday_month" }
  // { type: "date_range", from: "2026-03-01", to: "2026-03-10" }
  // { type: "first_invoice" }
  // { type: "all_of", rules: [...] } / { type: "any_of", rules: [...] }

  // Таргетинг
  target_type            varchar [not null, default: 'all']
  // 'all' | 'groups' | 'children' | 'tariff_types' | 'age_range'
  target_ids             uuid[]
  // для tariff_types: tariff_plan_id[]

  // Период действия
  valid_from             timestamptz [not null]
  valid_until            timestamptz

  // Лимиты использования
  max_uses_per_child     int
  total_max_uses         int
  used_count             int [not null, default: 0]

  // Приоритет (для пересекающихся скидок)
  priority               int [not null, default: 100]
  // чем выше число — тем выше приоритет применения
  stackable              boolean [not null, default: false]
  // можно ли применять вместе с другими скидками

  // Уведомления родителям
  notify_on_activation   boolean [not null, default: true]
  notification_title     jsonb // {ru, kz}
  notification_body      jsonb // {ru, kz}

  status                 custom_discount_status [not null, default: 'draft']
  created_by             uuid [ref: > staff_members.id]
  created_at             timestamptz [not null, default: `now()`]
  updated_at             timestamptz [not null, default: `now()`]

  indexes {
    (kindergarten_id, status)
    (valid_from, valid_until)
    (kindergarten_id, status, valid_from) [name: 'idx_custom_discounts_active']
  }
}

Table custom_discount_applications {
  id                   uuid [pk, default: `gen_random_uuid()`]
  kindergarten_id      uuid [not null, ref: > kindergartens.id]
  custom_discount_id   uuid [not null, ref: > custom_discounts.id]
  invoice_id           uuid [not null, ref: > invoices.id]
  invoice_line_item_id uuid [ref: > invoice_line_items.id]
  child_id             uuid [not null, ref: > children.id]
  amount_applied       decimal(12,2) [not null]
  applied_at           timestamptz [not null, default: `now()`]

  indexes {
    custom_discount_id
    invoice_id
    (child_id, custom_discount_id)
  }
}

// ─────────────────────────────────────────
// SQL-patches (вне DBML):
//   1. idx_child_guardians_approval_max2 — partial unique НЕ применима (WHERE has_approval_rights=TRUE
//      даёт ≤1, не ≤2). Реализовано через PL/pgSQL триггер
//      `trg_child_guardians_approval_max2` (BEFORE INSERT OR UPDATE):
//        COUNT(has_approval_rights = TRUE AND revoked_at IS NULL) <= 2 per child.
//      Migration: prisma/migrations/20260418022600_partial_indexes/migration.sql.
//
//   2. CREATE UNIQUE INDEX idx_children_iin_kindergarten
//      ON children(kindergarten_id, iin) WHERE iin IS NOT NULL; (partial unique — IIN nullable)
//      Prisma's @@unique генерит full unique, миграция дропает и пересоздаёт как partial.
//
//   3. CREATE INDEX idx_parent_requests_recipient
//      ON parent_requests(kindergarten_id, recipient_type, recipient_staff_id)
//      WHERE request_type = 'open_request';
//
//   4. pgvector расширение (для face_embeddings), либо Qdrant снаружи.
//
//   5. CREATE UNIQUE INDEX idx_group_mentors_one_active
//      ON group_mentors(staff_member_id) WHERE unassigned_at IS NULL;
//      — Правило: один mentor = ровно одна активная группа.
//
//   6. CREATE UNIQUE INDEX idx_group_mentors_one_primary_per_group
//      ON group_mentors(group_id) WHERE is_primary = TRUE AND unassigned_at IS NULL;
//      — Правило: у группы ровно один primary mentor.
//
//   7. CREATE UNIQUE INDEX idx_user_qr_tokens_one_active
//      ON user_qr_tokens(user_id, purpose)
//      WHERE revoked_at IS NULL;
//      — Правило: один активный токен на (user_id, purpose).
//        Без NOW() predicate (PG отвергает non-IMMUTABLE);
//        активность enforced в коде (revoke + insert TX).
//
//   8. (B24 Kaspi) UNIQUE на kaspi_merchant_session(kindergarten_id) — один
//      кассирский аккаунт Kaspi на садик. Реализуется через [unique] на
//      колонке (full unique, не partial — реконнект = UPDATE строки, не INSERT).
//
//   9. (B24 Kaspi) Single-row guard для kaspi_global_config:
//      ALTER TABLE kaspi_global_config ADD CONSTRAINT chk_kaspi_global_config_singleton CHECK (id = 1);
//      — гарантирует ровно одну строку глобального конфига. Seed-строка
//        вставляется в миграции (id=1, app_build текущий floor).
// ─────────────────────────────────────────
