# Copy this file to .env on the EC2 server and edit secrets before starting.

NODE_ENV=development
APP_PORT=3000
APP_NAME="Shyraq API"
API_PREFIX=api
APP_FALLBACK_LANGUAGE=kk
APP_HEADER_LANGUAGE=x-custom-lang

DATABASE_TYPE=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=shyraq

# Runtime app role. InitExtensions migration creates this role if missing.
DATABASE_USERNAME=shyraq_app
DATABASE_PASSWORD=shyraq_app

# Migration/bootstrap role used by TypeORM migrations.
DATABASE_MIGRATION_USERNAME=shyraq
DATABASE_MIGRATION_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

DATABASE_SUPERADMIN_USERNAME=shyraq_superadmin
DATABASE_SUPERADMIN_PASSWORD=shyraq_superadmin
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=20
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false
DATABASE_BYPASS_ROLE_CHECK=
DATABASE_URL=

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

AUTH_JWT_SECRET=CHANGE_ME_STRONG_RANDOM_JWT_SECRET
AUTH_JWT_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30
BCRYPT_COST=12

OTP_LENGTH=6
OTP_TTL_SECONDS=1800
OTP_TEST_PHONES=
OTP_TEST_CODE=000000

SUPER_ADMIN_SEED_EMAIL=admin@shyraq.local
SUPER_ADMIN_SEED_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

RATE_LIMIT_OTP_REQUEST_LIMIT=5
RATE_LIMIT_OTP_REQUEST_WINDOW_SEC=3600
RATE_LIMIT_SUPER_ADMIN_LOGIN_LIMIT=10
RATE_LIMIT_SUPER_ADMIN_LOGIN_WINDOW_SEC=3600

SMS_PROVIDER=mock
PAYMENT_PROVIDER=mock
FISCAL_PROVIDER=mock
OFD_PROVIDER=mock
FACE_PROVIDER=mock
PUSH_PROVIDER=mock

FILE_STORAGE_PROVIDER=local
FILE_STORAGE_LOCAL_DIR=uploads
