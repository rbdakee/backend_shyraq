# ============================================================
# Shyraq Backend v2 — Environment Variables
# Copy to .env for local dev. Validated at startup.
# ============================================================

# --- Runtime ---
NODE_ENV=development
APP_PORT=3000
APP_NAME="Shyraq API"
API_PREFIX=api
APP_FALLBACK_LANGUAGE=kk
APP_HEADER_LANGUAGE=x-custom-lang
FRONTEND_DOMAIN=http://localhost:3000
BACKEND_DOMAIN=http://localhost:3000

# --- PostgreSQL ---
# DATABASE_USERNAME / PASSWORD must be a non-superuser role (e.g. `shyraq_app`,
# created by InitExtensions migration). PostgreSQL exempts SUPERUSER (and
# BYPASSRLS) roles from row-level security regardless of FORCE RLS, so the
# bootstrap superuser cannot be used as the application connection.
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=shyraq_app
DATABASE_PASSWORD=shyraq_app
# Migration CLI uses DATABASE_MIGRATION_* if set (must own the schema —
# typically the bootstrap superuser). Falls back to DATABASE_USERNAME above.
DATABASE_MIGRATION_USERNAME=shyraq
DATABASE_MIGRATION_PASSWORD=shyraq
# Escape hatch for the runtime RLS role check (DbRoleCheckService). When
# unset (default), the app aborts startup if DATABASE_USERNAME maps to a
# SUPERUSER or BYPASSRLS role — PostgreSQL would silently bypass RLS. Set
# to `true` ONLY in dev sessions that intentionally connect with the
# bootstrap superuser. NEVER set this in production.
DATABASE_BYPASS_ROLE_CHECK=
DATABASE_NAME=shyraq
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false
DATABASE_CA=
DATABASE_KEY=
DATABASE_CERT=
DATABASE_URL=

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT / Refresh tokens (B1 v2) ---
# Access tokens — JWT HS256. Refresh tokens — opaque random hex (32B), SHA-256 hashed.
# No refresh-JWT secret.
AUTH_JWT_SECRET=replace-me-with-strong-random-access-secret
AUTH_JWT_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30

# --- Password hashing ---
# bcrypt cost: 12 in prod/dev (~250ms), 4 in test (~5ms).
BCRYPT_COST=12

# --- OTP ---
# 6-digit numeric code, 30-minute TTL by default.
OTP_LENGTH=6
OTP_TTL_SECONDS=1800

# --- SuperAdmin seed user ---
# Used by seed scripts to upsert bootstrap super_admin row.
# CHANGE BEFORE FIRST PRODUCTION DEPLOY.
SUPER_ADMIN_SEED_EMAIL=admin@shyraq.local
SUPER_ADMIN_SEED_PASSWORD=admin123

# --- OTP test backdoor ---
# CSV of phone numbers that bypass real SMS send and accept OTP_TEST_CODE.
# Leave empty in production. Active when non-empty.
OTP_TEST_PHONES=
OTP_TEST_CODE=000000

# --- Rate limiting ---
RATE_LIMIT_OTP_REQUEST_LIMIT=5
RATE_LIMIT_OTP_REQUEST_WINDOW_SEC=3600
RATE_LIMIT_SUPER_ADMIN_LOGIN_LIMIT=10
RATE_LIMIT_SUPER_ADMIN_LOGIN_WINDOW_SEC=3600

# --- Providers (all default to mock until real credentials added) ---
# SMS_PROVIDER selects the SmsPort adapter wired into AuthModule. Used for OTP
# delivery (auth, parent-request, pickup) and welcome notifications.
# 'mock'      — logs the message; never hits the network. Default.
# 'whatsapp'  — Meta WhatsApp Cloud API.
#               * Auth-login OTP and parent-request OTP go through a pre-approved
#                 Authentication-category TEMPLATE (default `otp_ru`) — bypasses
#                 the 24h customer-service window, works for cold recipients.
#               * Pickup-request OTP and all welcome/admin-invite messages still
#                 use FREEFORM text (single-variable template can't carry the
#                 child/kindergarten context). Freeform requires the recipient
#                 to have messaged the WABA number within 24h, otherwise Meta
#                 rejects with code 131047.
SMS_PROVIDER=mock

# WhatsApp Cloud API credentials (required only when SMS_PROVIDER=whatsapp).
# Find them in Meta for Developers → your App → WhatsApp → API Setup.
# WHATSAPP_PHONE_NUMBER_ID — id of the WABA phone number that SENDS messages.
# WHATSAPP_ACCESS_TOKEN    — System User permanent token (preferred) or
#                            temporary 24h token (dev only).
# WHATSAPP_API_VERSION     — Graph API version, defaults to v21.0.
# WHATSAPP_BUSINESS_ACCOUNT_ID — informational only (logged for diagnostics).
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_API_VERSION=v21.0
# WHATSAPP_BUSINESS_ACCOUNT_ID=
#
# OTP template (Authentication category, approved in Meta Business Manager).
# WHATSAPP_OTP_TEMPLATE_NAME       — template name, default `otp_ru`.
# WHATSAPP_OTP_TEMPLATE_LANGUAGE   — BCP-47 language code matching the template
#                                    language, default `ru`.
# WHATSAPP_OTP_TEMPLATE_HAS_BUTTON — `true` (default) if the template has a
#                                    one-tap/copy-code button — Meta's
#                                    Authentication wizard includes one by
#                                    default and the API then requires the code
#                                    passed both in body AND in button
#                                    parameter. Set `false` for body-only.
# WHATSAPP_OTP_TEMPLATE_NAME=otp_ru
# WHATSAPP_OTP_TEMPLATE_LANGUAGE=ru
# WHATSAPP_OTP_TEMPLATE_HAS_BUTTON=true
#
# Dev-only escape hatch: reroute every outgoing WhatsApp message to a single
# wa_id. Useful **only** for Meta test-sandbox numbers (the +1 555 ... numbers
# Meta gives out before a real WABA is wired up), where the recipient must be
# in a 5-entry whitelist managed via the Meta dashboard. The dashboard has a
# bug for +7 numbers — it silently inserts the local trunk-prefix `8`, storing
# `787772270088` in the whitelist instead of `77772270088`. Meta's whitelist
# matcher is a literal string compare (not wa_id normalization), so our
# adapter's correctly-normalized E.164 output gets rejected with code 131030
# even though the wa_id is the same. The override re-routes every send to the
# wa_id Meta actually has in its whitelist.
#
# A production / real-number WABA does NOT need this — real numbers have no
# whitelist and Meta normalizes wa_ids consistently. Leave UNSET in production.
# When set and NODE_ENV !== production, the adapter emits a startup WARN and
# a per-send WARN with masked phone. Ignored in production.
# WHATSAPP_DEV_RECIPIENT_OVERRIDE=

# --- Billing & payments (B13) ---
# PAYMENT_PROVIDER selects the payment-provider adapter wired into BillingModule.
# Default 'mock' — synchronous in-memory mock for dev/test/demo. Real providers
# (Halyk ePay, Kaspi, FreedomPay, TipTopPay) come in B14 / Phase B; configure
# their credentials below.
PAYMENT_PROVIDER=mock
# Halyk ePay: requires merchant credentials when PAYMENT_PROVIDER=halyk.
# HALYK_MERCHANT_ID=
# HALYK_API_KEY=

# FISCAL_PROVIDER selects the OFD fiscal-receipt adapter.
# Default 'mock' — logs receipts and returns a deterministic fiscal sign so
# tests can assert receipt emission without standing up a real OFD. Real
# providers (Kassa24 / Rekassa / Webkassa) come in B15 / Phase B.
FISCAL_PROVIDER=mock
# Legacy alias kept for existing deployments — superseded by FISCAL_PROVIDER.
OFD_PROVIDER=mock

FACE_PROVIDER=mock

# --- File storage (B17) ---
# FILE_STORAGE_PROVIDER selects the FileStoragePort adapter for media uploads
# (content_posts.media_urls, group_stories.media_url).
# WARNING: 's3' / 'yandex' currently throw `NotImplementedError` at adapter init — only 'local' is functional in Phase A. Real adapters are Phase B.
FILE_STORAGE_PROVIDER=local
# S3-compatible: requires credentials when FILE_STORAGE_PROVIDER=s3 or yandex.
# FILE_STORAGE_BUCKET=
# FILE_STORAGE_REGION=
# FILE_STORAGE_ACCESS_KEY=
# FILE_STORAGE_SECRET_KEY=
# FILE_STORAGE_ENDPOINT=   # Yandex Object Storage: https://storage.yandexcloud.net

# --- Push notifications (B9) ---
# PUSH_PROVIDER selects the PushNotificationPort adapter for mobile push.
# 'mock' | 'fcm'. Real FCM adapter is Phase B (stub exists today, switches by env).
PUSH_PROVIDER=mock
# FCM credentials only required when PUSH_PROVIDER=fcm.
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# --- Multi-tenancy (RLS) ---
# DB role used by app — must NOT have BYPASSRLS. SuperAdmin queries use a separate role.
# DATABASE_USERNAME above is the regular tenant-scoped role.
DATABASE_SUPERADMIN_USERNAME=shyraq_superadmin
DATABASE_SUPERADMIN_PASSWORD=shyraq_superadmin

# --- BullMQ cron toggles (B22a T3) ---
# Each processor schedules its repeatable BullMQ job at OnApplicationBootstrap
# unless the matching `*_CRON` env var is set to `disabled`. When the worker
# process hosts the recurring slot (`npm run start:worker`), set the SAME
# variable to `disabled` for the api process so the two never compete to
# enqueue the same tick. Default (unset / `enabled`) keeps the api scheduling
# the cron — single-process dev mode "just works".
#
# Pattern:
#   api  .env: BILLING_MONTHLY_CRON=disabled (etc.)
#   worker .env: BILLING_MONTHLY_CRON=enabled (or unset)
# BILLING_MONTHLY_CRON=enabled
# BILLING_DISCOUNT_EXPIRE_CRON=enabled
# BILLING_OVERDUE_CRON=enabled
# CONTENT_PUBLISH_CRON=enabled
# BIRTHDAY_GENERATION_CRON=enabled
# STORY_CLEANUP_CRON=enabled
# OUTBOX_PRUNE_CRON=enabled
#
# Notes on outbox-prune retention (B22b T12): the weekly cron deletes
# terminal `notification_outbox` rows older than 7 days (dispatched)
# and 30 days (failed). Retention windows are HARDCODED in
# `src/modules/notification/outbox-prune.processor.ts` — not via env —
# because a misconfigured window is more dangerous (silent data loss
# from a typo) than a hardcoded one. Change the constants when
# compliance or audit requirements push us to a different horizon.
