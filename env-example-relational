# ============================================================
# Shyraq Backend v2 — Environment Variables
# Copy to .env for local dev. Validated at startup.
# ============================================================

# --- Runtime ---
NODE_ENV=development
APP_PORT=3000
APP_NAME="Shyraq API"
API_PREFIX=api
APP_FALLBACK_LANGUAGE=kk
APP_HEADER_LANGUAGE=x-custom-lang
FRONTEND_DOMAIN=http://localhost:3000
BACKEND_DOMAIN=http://localhost:3000

# --- PostgreSQL ---
# DATABASE_USERNAME / PASSWORD must be a non-superuser role (e.g. `shyraq_app`,
# created by InitExtensions migration). PostgreSQL exempts SUPERUSER (and
# BYPASSRLS) roles from row-level security regardless of FORCE RLS, so the
# bootstrap superuser cannot be used as the application connection.
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=shyraq_app
DATABASE_PASSWORD=shyraq_app
# Migration CLI uses DATABASE_MIGRATION_* if set (must own the schema —
# typically the bootstrap superuser). Falls back to DATABASE_USERNAME above.
DATABASE_MIGRATION_USERNAME=shyraq
DATABASE_MIGRATION_PASSWORD=shyraq
# Escape hatch for the runtime RLS role check (DbRoleCheckService). When
# unset (default), the app aborts startup if DATABASE_USERNAME maps to a
# SUPERUSER or BYPASSRLS role — PostgreSQL would silently bypass RLS. Set
# to `true` ONLY in dev sessions that intentionally connect with the
# bootstrap superuser. NEVER set this in production.
DATABASE_BYPASS_ROLE_CHECK=
DATABASE_NAME=shyraq
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false
DATABASE_CA=
DATABASE_KEY=
DATABASE_CERT=
DATABASE_URL=

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT / Refresh tokens (B1 v2) ---
# Access tokens — JWT HS256. Refresh tokens — opaque random hex (32B), SHA-256 hashed.
# No refresh-JWT secret.
AUTH_JWT_SECRET=replace-me-with-strong-random-access-secret
AUTH_JWT_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30

# --- Password hashing ---
# bcrypt cost: 12 in prod/dev (~250ms), 4 in test (~5ms).
BCRYPT_COST=12

# --- OTP ---
# 6-digit numeric code, 5-minute TTL by default.
OTP_LENGTH=6
OTP_TTL_SECONDS=300

# --- SuperAdmin seed user ---
# Used by seed scripts to upsert bootstrap super_admin row.
# CHANGE BEFORE FIRST PRODUCTION DEPLOY.
SUPER_ADMIN_SEED_EMAIL=admin@shyraq.local
SUPER_ADMIN_SEED_PASSWORD=admin123

# --- OTP test backdoor ---
# CSV of phone numbers that bypass real SMS send and accept OTP_TEST_CODE.
# Leave empty in production. Active when non-empty.
OTP_TEST_PHONES=
OTP_TEST_CODE=000000

# --- Rate limiting ---
RATE_LIMIT_OTP_REQUEST_LIMIT=5
RATE_LIMIT_OTP_REQUEST_WINDOW_SEC=3600
RATE_LIMIT_SUPER_ADMIN_LOGIN_LIMIT=10
RATE_LIMIT_SUPER_ADMIN_LOGIN_WINDOW_SEC=3600

# --- Providers (all default to mock until real credentials added) ---
SMS_PROVIDER=mock
PAYMENT_PROVIDER=mock
OFD_PROVIDER=mock
FACE_PROVIDER=mock

# --- Multi-tenancy (RLS) ---
# DB role used by app — must NOT have BYPASSRLS. SuperAdmin queries use a separate role.
# DATABASE_USERNAME above is the regular tenant-scoped role.
DATABASE_SUPERADMIN_USERNAME=shyraq_superadmin
DATABASE_SUPERADMIN_PASSWORD=shyraq_superadmin
